http://localhost, https://localhost {
    handle /api/* {
        reverse_proxy backend:7772    
    }

    handle /scalar {
        rewrite * /index.html
        root * /srv
        file_server
    }

    handle /health {
        respond "OK" 200
    }

    handle {
        reverse_proxy frontend:7771
    }
}

