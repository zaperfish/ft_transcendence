  "panels": [
    {
      "datasource": "Prometheus",
      "description": "how many GC cycles per second happened on average over the last 1 minute? Expected behavior after GC pressure -> upward spike, then downward to come back close to 0.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "rate(go_gc_duration_seconds_count{job=\"backend\"}[1m])",
          "instant": false,
          "legendFormat": "GC cycles/sec",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "GC Cycles/sec",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "shows how many bytes are currently allocated on the backend Go heap. Expected behavior after GC pressure -> heap rises while the script holds temporary memory, then drops after the memory is released and Go runs GC.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "go_memstats_heap_alloc_bytes{job=\"backend\"}",
          "instant": false,
          "legendFormat": "heap allocated",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Heap Allocated Bytes",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "shows how many bytes per second the backend allocated on average over the last 1 minute. Expected behavior after GC pressure -> allocation rate rises while the script creates temporary memory, then gradually falls back toward the normal baseline after the script stops.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "rate(go_memstats_alloc_bytes_total{job=\"backend\"}[1m])",
          "instant": false,
          "legendFormat": "allocated bytes/sec",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Allocation Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "shows how much physical memory the backend process currently holds from the OS perspective. Expected behavior after GC pressure -> resident memory rises during allocation and may stay elevated even after Heap Allocated Bytes drops, because Go can keep memory reserved for reuse instead of immediately returning it to the OS.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
