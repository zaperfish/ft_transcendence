    {
      "datasource": "Prometheus",
      "description": "shows the current GOMAXPROCS value, which is the number of OS threads that can execute Go code at the same time. Expected behavior -> this should stay flat unless runtime CPU limits or explicit GOMAXPROCS configuration change.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
