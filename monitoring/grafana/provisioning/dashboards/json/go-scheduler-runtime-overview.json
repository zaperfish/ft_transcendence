    {
      "datasource": "Prometheus",
      "description": "shows how many CPU seconds per second the backend process used on average over the last 1 minute. A value near 1 means roughly one CPU core is fully used. Expected behavior after CPU scheduler pressure -> upward spike while CPU-bound goroutines run, then a return toward the normal baseline.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
